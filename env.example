# WardrobeIQ — Environment Variables
# Copy this file to .env and fill in your values
# For deployment (Render/Railway): add these in the dashboard, NOT here

# ── Flask ──
SECRET_KEY=change_this_to_a_random_secret_string_in_production
FLASK_DEBUG=true   # set to false in production

# ── Database (local) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wardrobe_db
DB_USER=postgres
DB_PASSWORD=wardrobe123

# ── Database (Render/Railway) ──
# Render provides DATABASE_URL automatically when you add a PostgreSQL service
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ── Email (Gmail) ──
# Steps:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (MUST be ON)
#   2. Security → App passwords → Generate → Copy 16-char password
#   3. Paste below (spaces are fine, e.g. "abcd efgh ijkl mnop")
EMAIL_SENDER=menariaprachi0@gmail.com
EMAIL_PASSWORD=abcd nmnb heja pwas hxpp
